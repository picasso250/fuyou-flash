        # 提取回复区内容
        raw_content = parts[1].split("--- 圣言录 ---")[0].strip()
        if raw_content and "(请在此处输入您的指示" not in raw_content:
            host_instruction = raw_content
            instruction_received = True

# --- 市场脉动：BTC 实时观测 ---
