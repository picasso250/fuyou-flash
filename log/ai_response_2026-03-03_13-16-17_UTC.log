sim_value_saved = 0.0
if abs(delta_pct) > 1.0: # 波动超过 1%，防御价值更高
    sim_value_saved = abs(delta) * 0.001 
elif abs(delta_pct) > 0.5:
    sim_value_saved = abs(delta) * 0.0005
