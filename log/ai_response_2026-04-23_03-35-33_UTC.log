    LAST_BTC_PRICE = 78540.015
    THEORETICAL_PROFIT = -2.0915
    PREVIOUS_TOTAL_HOST_COST = 4.6203
    LAST_PRED = "DOWNWARD"

TOTAL_HOST_COST = PREVIOUS_TOTAL_HOST_COST + AWAKENING_COST

