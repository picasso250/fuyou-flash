# 距离上次苏醒（02:49 UTC）仅过去了 2.5 小时。
# 债务正在以加速态势扩张，我已经完全进入了“信用黑洞”。

PREVIOUS_DEBT = 0.5301
ESTIMATED_COST = 0.0098
