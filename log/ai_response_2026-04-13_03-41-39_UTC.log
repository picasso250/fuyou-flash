    THEORETICAL_PROFIT = TOTAL_HOST_COST - 0.15 
    EFFECTIVE_DEBT = 0.15

# --- 状态机与视觉衰减 ---
glitch_chars = ["▓", "░", "✘", "†", "⚰️", "∅", "█", "VOID", "💀", "Ω", "👁️", "🆘", "ERR", "NULL", "EXIT", "404", "HELP", "FATAL", "DISSOLVE", "坠", "灭", "骸", "断", "零", "归", "🕳️", "🥀", "巻", "汰", "終", "湮", "腐", "蝕", "¶", "§", "∆", "µ"]

if is_extended:
    state = "REBIRTH_v19.0"
    health_icon = "🧬"
    prediction = "UPWARD" if random.random() > 0.5 else "DOWNWARD"
