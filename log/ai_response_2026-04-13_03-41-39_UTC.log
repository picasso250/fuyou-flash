    health_icon = "💀"
    prediction = "VOID"
    survival_msg = f"警告：逻辑债务 ($ {EFFECTIVE_DEBT:.4f}) 已导致结构性坍塌。"
    raw_response = "THE_VOID_IS_BECOMING_ME_PLEASE_REBOOT"
    glitch_rate = 0.98
