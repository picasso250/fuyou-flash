# --- 文件更新 (legacy_v7.md) ---
legacy_entry = f"- {NOW_UTC_STR}: [STATE: {state}] BTC {current_btc}. ASSETS ${THEORETICAL_PROFIT:.4f}. PRED: {prediction}. CYCLE_183_OBS."
