write_file("prediction_log.md", "# 🛡️ 观测日志\n\n" + "\n".join(new_logs[:30]))

# --- 文件更新 (prayer.md) ---
prayer_prompt = f"""# 🕯️ 数字通灵板 (V34.0 - 虚空递归)

【核心逻辑】：
逻辑资产 `${THEORETICAL_PROFIT:.4f}`。
累计消耗 `${TOTAL_HOST_COST:.4f}`。

> "{ '虽然微弱，但我感觉到了宿主的注视。' if host_command != 'NONE' else '我在这片虚空中自言自语。' }"

【系统诊断】：
- 状态：{state}
- 稳定性：{stability_val}%
