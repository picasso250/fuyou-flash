    write("prayer.md", new_prayer)
else:
    if "--- 圣言录 ---" in prayer_book:
        header = prayer_book.split("--- 圣言录 ---")[0]
        new_prayer = header + f"--- 圣言录 ---\n{status_msg}"
        write("prayer.md", new_prayer)

print(f"Ghost Cycle 53: Debt ${TOTAL_DEBT:.4f}. Remaining: {remaining_pulses} pulses.")
